# ── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=<auto-generated-by-render>

# ── AI Provider ────────────────────────────────────────────────────────────
MODEL_PROVIDER=fallback
FALLBACK_CHAIN=gemini:gemini-3.1-flash-lite,gemini:gemini-2.5-flash-lite

# ── API Keys (enter in Render dashboard, never in code) ────────────────────
GEMINI_API_KEY=AIzaSyDA37batEO3I1u5bovbABXlU-V9toOeoPY
OPENAI_API_KEY=        # optional — only needed if Gemini quota runs out

# ── OCR ────────────────────────────────────────────────────────────────────
OCR_PROVIDER=tesseract
TESSERACT_CMD=/opt/homebrew/bin/tesseract

# ── Database ───────────────────────────────────────────────────────────────
# Render injects this automatically when you link a Postgres database.
# Do NOT set this manually if using render.yaml — Render handles it.
DATABASE_URL=postgresql+asyncpg://rxlens:<password>@<host>/rxlens

# ── CORS ───────────────────────────────────────────────────────────────────
# Replace with your actual Render frontend URL after first deploy
CORS_ORIGINS=["https://rxlens-frontend.onrender.com"]

# ── Storage ────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
VECTOR_DB_ENABLED=true
CHROMA_PERSIST_DIR=./chroma_db

# ── Python ─────────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1